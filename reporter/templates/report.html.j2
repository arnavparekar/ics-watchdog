<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ICS-Watchdog — Security Report</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --bg:          #0a0a0f;
            --bg-card:     #111118;
            --bg-card-alt: #16161e;
            --border:      #2a2a38;
            --border-dim:  #1e1e28;
            --text:        #e4e4f0;
            --text-muted:  #8888a8;
            --text-dim:    #55556a;
            --accent:      #00d4ff;      /* cold cyan — fits ICS/OT aesthetic */
            --accent-dim:  rgba(0, 212, 255, 0.08);
            --accent-glow: rgba(0, 212, 255, 0.18);
            --critical:    #ff4c4c;
            --high:        #ff8c42;
            --medium:      #f0c040;
            --low:         #4c9fff;
        }

        body {
            margin: 0;
            padding: 0;
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* ── Top bar ── */
        .topbar {
            background: var(--bg-card);
            border-bottom: 1px solid var(--border);
            padding: 0 40px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.5px;
            color: var(--text);
        }

        .topbar-brand .dot {
            width: 9px;
            height: 9px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--accent);
            animation: pulse 2.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.4; }
        }

        .topbar-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: var(--text-muted);
        }

        /* ── Page layout ── */
        .page {
            max-width: 1280px;
            margin: 0 auto;
            padding: 40px 40px 80px;
        }

        .page-header {
            margin-bottom: 40px;
        }

        .page-header h2 {
            margin: 0 0 4px;
            font-size: 22px;
            font-weight: 600;
            color: var(--text);
        }

        .page-header p {
            margin: 0;
            color: var(--text-muted);
            font-size: 13px;
        }

        /* ── Summary cards ── */
        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 22px 24px;
            transition: border-color 0.2s, transform 0.2s;
        }

        .card:hover {
            border-color: var(--accent);
            transform: translateY(-1px);
        }

        .card-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .card-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 28px;
            font-weight: 700;
            color: var(--text);
            line-height: 1;
        }

        .card-value.danger {
            color: var(--critical);
            text-shadow: 0 0 16px rgba(255, 76, 76, 0.3);
        }

        .card-sub {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 6px;
        }

        /* ── Charts ── */
        .charts {
            display: grid;
            grid-template-columns: 340px 1fr;
            gap: 16px;
            margin-bottom: 32px;
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 24px;
        }

        .chart-card h3 {
            margin: 0 0 20px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .chart-wrap {
            position: relative;
            height: 260px;
        }

        /* ── Severity breakdown legend ── */
        .sev-legend {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 20px;
        }

        .sev-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 12px;
        }

        .sev-row .name {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
        }

        .sev-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .sev-row .count {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            color: var(--text);
            font-weight: 500;
        }

        /* ── Alert table ── */
        .table-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .table-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .table-header h3 {
            margin: 0;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .table-header .count-chip {
            background: var(--accent-dim);
            border: 1px solid var(--accent-glow);
            color: var(--accent);
            font-size: 11px;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            padding: 3px 9px;
            border-radius: 20px;
            letter-spacing: 0.5px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            padding: 10px 20px;
            font-size: 10.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            background: var(--bg-card-alt);
            border-bottom: 1px solid var(--border-dim);
        }

        td {
            padding: 13px 20px;
            border-bottom: 1px solid var(--border-dim);
            vertical-align: top;
        }

        tr:last-child td { border-bottom: none; }

        tbody tr:hover td {
            background: var(--bg-card-alt);
        }

        /* ── Severity badges ── */
        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }
        .badge-CRITICAL { background: rgba(255,76,76,0.12);  color: var(--critical); border: 1px solid rgba(255,76,76,0.28); }
        .badge-HIGH     { background: rgba(255,140,66,0.12); color: var(--high);     border: 1px solid rgba(255,140,66,0.28); }
        .badge-MEDIUM   { background: rgba(240,192,64,0.12); color: var(--medium);   border: 1px solid rgba(240,192,64,0.28); }
        .badge-LOW      { background: rgba(76,159,255,0.12); color: var(--low);      border: 1px solid rgba(76,159,255,0.28); }

        /* ── Misc ── */
        .mono { font-family: 'JetBrains Mono', monospace; }

        .rule-id {
            color: var(--accent);
            font-weight: 600;
            font-size: 12px;
        }

        .rule-name {
            color: var(--text-muted);
            font-size: 11.5px;
            margin-top: 1px;
        }

        .mitre-tag {
            color: var(--text-dim);
            font-size: 10.5px;
            font-family: 'JetBrains Mono', monospace;
            margin-top: 2px;
        }

        .explanation {
            color: var(--text-muted);
            font-size: 12.5px;
            line-height: 1.5;
            max-width: 420px;
        }
    </style>
</head>
<body>

<!-- Top navigation bar -->
<div class="topbar">
    <div class="topbar-brand">
        <span class="dot"></span>
        ICS-Watchdog
    </div>
    <div class="topbar-meta">
        Passive Modbus/TCP Monitor &nbsp;|&nbsp;
        Report Date: {{ report.alerts[-1].timestamp[:10] if report.alerts else 'N/A' }}
    </div>
</div>

<div class="page">

    <!-- Page heading -->
    <div class="page-header">
        <h2>Security Event Report</h2>
        <p>Aggregated from passive Modbus/TCP network capture. No probes or active traffic were generated by the monitor.</p>
    </div>

    <!-- Summary metrics -->
    <div class="cards">
        <div class="card">
            <div class="card-label">Run Duration</div>
            <div class="card-value">{{ "%.0f"|format(report.summary.run_duration_seconds) }}<span style="font-size:14px;color:var(--text-muted);font-weight:400"> s</span></div>
            <div class="card-sub">Passive capture window</div>
        </div>
        <div class="card">
            <div class="card-label">Total Packets</div>
            <div class="card-value">{{ report.summary.total_packets_captured }}</div>
            <div class="card-sub">Observed on wire</div>
        </div>
        <div class="card">
            <div class="card-label">Modbus Packets</div>
            <div class="card-value">{{ report.summary.modbus_packets }}</div>
            <div class="card-sub">TCP port 502 requests</div>
        </div>
        <div class="card">
            <div class="card-label">Total Alerts</div>
            <div class="card-value danger">{{ report.summary.total_alerts }}</div>
            <div class="card-sub">Rule engine detections</div>
        </div>
    </div>

    <!-- Charts row -->
    <div class="charts">

        <!-- Severity donut -->
        <div class="chart-card">
            <h3>Alerts by Severity</h3>
            <div class="chart-wrap">
                <canvas id="sevChart"></canvas>
            </div>
            <div class="sev-legend">
                {% set sev = report.summary.alerts_by_severity %}
                <div class="sev-row">
                    <span class="name"><span class="sev-dot" style="background:var(--critical)"></span>Critical</span>
                    <span class="count">{{ sev.get('CRITICAL', 0) }}</span>
                </div>
                <div class="sev-row">
                    <span class="name"><span class="sev-dot" style="background:var(--high)"></span>High</span>
                    <span class="count">{{ sev.get('HIGH', 0) }}</span>
                </div>
                <div class="sev-row">
                    <span class="name"><span class="sev-dot" style="background:var(--medium)"></span>Medium</span>
                    <span class="count">{{ sev.get('MEDIUM', 0) }}</span>
                </div>
                <div class="sev-row">
                    <span class="name"><span class="sev-dot" style="background:var(--low)"></span>Low</span>
                    <span class="count">{{ sev.get('LOW', 0) }}</span>
                </div>
            </div>
        </div>

        <!-- FC bar chart -->
        <div class="chart-card">
            <h3>Function Code Distribution</h3>
            <div class="chart-wrap">
                <canvas id="fcChart"></canvas>
            </div>
        </div>

    </div>

    <!-- Alert table -->
    <div class="table-card">
        <div class="table-header">
            <h3>Detected Security Events</h3>
            <span class="count-chip">{{ report.summary.total_alerts }} events</span>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Time (UTC)</th>
                    <th>Severity</th>
                    <th>Rule &amp; MITRE ID</th>
                    <th>Source IP</th>
                    <th>Destination IP</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for alert in report.alerts | reverse %}
                <tr>
                    <td class="mono" style="color:var(--text-muted);white-space:nowrap;font-size:12px">
                        {{ alert.timestamp[11:19] }}
                    </td>
                    <td>
                        <span class="badge badge-{{ alert.severity }}">{{ alert.severity }}</span>
                    </td>
                    <td>
                        <div class="rule-id">{{ alert.rule_id }}</div>
                        <div class="rule-name">{{ alert.rule_name }}</div>
                        <div class="mitre-tag">{{ alert.mitre_technique }} · {{ alert.mitre_name }}</div>
                    </td>
                    <td class="mono" style="font-size:12px;white-space:nowrap">{{ alert.src_ip }}</td>
                    <td class="mono" style="font-size:12px;white-space:nowrap">{{ alert.dst_ip }}</td>
                    <td class="explanation">{{ alert.explanation }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div><!-- /page -->

<script>
(function() {
    // ── Shared chart defaults ──────────────────────────────────────────
    Chart.defaults.color = '#8888a8';
    Chart.defaults.font.family = "'Inter', sans-serif";

    // ── Severity Donut ─────────────────────────────────────────────────
    const sevData = {{ report.summary.alerts_by_severity | tojson }};
    const sevLabels = ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW'];
    const sevColors = ['#ff4c4c', '#ff8c42', '#f0c040', '#4c9fff'];
    const sevCounts = sevLabels.map(l => sevData[l] || 0);

    new Chart(document.getElementById('sevChart'), {
        type: 'doughnut',
        data: {
            labels: sevLabels,
            datasets: [{
                data: sevCounts,
                backgroundColor: sevColors.map(c => c + '33'),
                borderColor: sevColors,
                borderWidth: 1.5,
                hoverOffset: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: (ctx) => `  ${ctx.label}: ${ctx.raw}`
                    }
                }
            }
        }
    });

    // ── FC Distribution Bar ────────────────────────────────────────────
    const fcRaw = {{ report.network_stats.function_codes | tojson }};
    const fcLabels = Object.keys(fcRaw);
    const fcCounts = Object.values(fcRaw);

    new Chart(document.getElementById('fcChart'), {
        type: 'bar',
        data: {
            labels: fcLabels,
            datasets: [{
                label: 'Packets',
                data: fcCounts,
                backgroundColor: 'rgba(0, 212, 255, 0.15)',
                borderColor: 'rgba(0, 212, 255, 0.6)',
                borderWidth: 1,
                borderRadius: 3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    ticks: { font: { size: 10 }, maxRotation: 35 },
                    grid: { color: '#1e1e28' }
                },
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 },
                    grid: { color: '#1e1e28' }
                }
            },
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: (ctx) => `  ${ctx.raw} packets`
                    }
                }
            }
        }
    });
})();
</script>

</body>
</html>
