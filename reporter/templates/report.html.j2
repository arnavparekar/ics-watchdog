<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ICS-Watchdog Report</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #09090b;
            --bg-card: #18181b;
            --bg-card-hover: #27272a;
            --text-main: #f4f4f5;
            --text-muted: #a1a1aa;
            --accent-primary: #06b6d4; /* Cyan */
            --accent-glow: rgba(6, 182, 212, 0.2);
            --alert-critical: #ef4444;
            --alert-high: #f97316;
            --alert-medium: #eab308;
            --alert-low: #3b82f6;
            --border-color: #3f3f46;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 30px 20px;
            line-height: 1.6;
        }

        h1, h2, h3 {
            margin-top: 0;
            font-weight: 600;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 40px;
        }

        .header-title h1 {
            font-size: 2rem;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-title h1::before {
            content: '';
            display: inline-block;
            width: 12px;
            height: 12px;
            background-color: var(--accent-primary);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent-primary);
        }

        .header-title p {
            color: var(--text-muted);
            margin: 0;
            font-size: 0.95rem;
        }

        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4), 0 0 15px var(--accent-glow);
            border-color: var(--accent-primary);
        }

        .card-title {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .card-value {
            font-size: 2.5rem;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-main);
        }

        .charts-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 40px;
        }

        .chart-box {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            height: 350px;
        }

        .alerts-table-container {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            overflow-x: auto;
        }

        .alerts-table-container h2 {
            font-size: 1.2rem;
            margin-bottom: 20px;
            color: var(--text-main);
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            text-align: left;
        }

        th, td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            background-color: #1f1f22;
        }
        
        th:first-child { border-top-left-radius: 6px; }
        th:last-child { border-top-right-radius: 6px; }

        tr:last-child td { border-bottom: none; }

        tr:hover td {
            background-color: var(--bg-card-hover);
        }

        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .severity-CRITICAL { background-color: rgba(239, 68, 68, 0.15); color: var(--alert-critical); border: 1px solid rgba(239, 68, 68, 0.3); }
        .severity-HIGH { background-color: rgba(249, 115, 22, 0.15); color: var(--alert-high); border: 1px solid rgba(249, 115, 22, 0.3); }
        .severity-MEDIUM { background-color: rgba(234, 179, 8, 0.15); color: var(--alert-medium); border: 1px solid rgba(234, 179, 8, 0.3); }
        .severity-LOW { background-color: rgba(59, 130, 246, 0.15); color: var(--alert-low); border: 1px solid rgba(59, 130, 246, 0.3); }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
        }
        
        .rule-id {
            color: var(--accent-primary);
            font-weight: 600;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="header-title">
            <h1>ICS-Watchdog</h1>
            <p>Passive Modbus/TCP Security Monitoring Report</p>
        </div>
        <div class="header-meta">
            <p class="mono" style="color: var(--text-muted); margin: 0;">Generated: <span style="color: var(--text-main);">{{ report.alerts[-1].timestamp[:10] if report.alerts else 'N/A' }}</span></p>
        </div>
    </div>

    <!-- Summary Metrics -->
    <div class="summary-cards">
        <div class="card">
            <div class="card-title">Duration (s)</div>
            <div class="card-value">{{ report.summary.run_duration_seconds | round(2) }}</div>
        </div>
        <div class="card">
            <div class="card-title">Total Packets</div>
            <div class="card-value">{{ report.summary.total_packets_captured }}</div>
        </div>
        <div class="card">
            <div class="card-title">Modbus Packets</div>
            <div class="card-value">{{ report.summary.modbus_packets }}</div>
        </div>
        <div class="card" style="border-color: rgba(239, 68, 68, 0.3);">
            <div class="card-title">Total Alerts</div>
            <div class="card-value" style="color: var(--alert-critical); text-shadow: 0 0 10px rgba(239, 68, 68, 0.4);">{{ report.summary.total_alerts }}</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-container">
        <div class="chart-box">
            <canvas id="severityChart"></canvas>
        </div>
        <div class="chart-box">
            <canvas id="fcChart"></canvas>
        </div>
    </div>

    <!-- Alert Table -->
    <div class="alerts-table-container">
        <h2>Detected Security Events</h2>
        <table>
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Severity</th>
                    <th>Rule / MITRE</th>
                    <th>Src IP</th>
                    <th>Dst IP</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for alert in report.alerts | reverse %}
                <tr>
                    <td class="mono" style="color: var(--text-muted);">{{ alert.timestamp[11:19] }}</td>
                    <td><span class="badge severity-{{ alert.severity }}">{{ alert.severity }}</span></td>
                    <td>
                        <span class="rule-id">{{ alert.rule_id }}</span>
                        <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 2px;">{{ alert.rule_name }}</div>
                        <div style="font-size: 0.75rem; color: #52525b; margin-top: 2px;">{{ alert.mitre_technique }}</div>
                    </td>
                    <td class="mono">{{ alert.src_ip }}</td>
                    <td class="mono">{{ alert.dst_ip }}</td>
                    <td style="font-size: 0.9rem; color: #d4d4d8;">{{ alert.explanation }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
    // Prepare Data for Severity Chart
    const severityData = {{ report.summary.alerts_by_severity | tojson }};
    const severityCtx = document.getElementById('severityChart').getContext('2d');
    
    // Ensure all standard severities are represented even if 0
    const labels = ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW'];
    const data = labels.map(l => severityData[l] || 0);
    const colors = ['#ef4444', '#f97316', '#eab308', '#3b82f6'];

    new Chart(severityCtx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: colors,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { color: '#fff' } },
                title: { display: true, text: 'Alerts by Severity', color: '#fff', font: { size: 16 } }
            }
        }
    });

    // Prepare Data for Function Code Chart
    const fcDataRaw = {{ report.network_stats.function_codes | tojson }};
    // Filter out internal zero counts if needed, or map common ones
    const fcLabels = Object.keys(fcDataRaw).map(fc => `FC ${fc.padStart(2, '0')}`);
    const fcCounts = Object.values(fcDataRaw);
    
    const fcCtx = document.getElementById('fcChart').getContext('2d');
    new Chart(fcCtx, {
        type: 'bar',
        data: {
            labels: fcLabels,
            datasets: [{
                label: 'Packet Count',
                data: fcCounts,
                backgroundColor: '#3b82f6',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true, grid: { color: '#333' }, ticks: { color: '#b3b3b3' } },
                x: { grid: { display: false }, ticks: { color: '#b3b3b3' } }
            },
            plugins: {
                legend: { display: false },
                title: { display: true, text: 'Modbus Function Codes Observed', color: '#fff', font: { size: 16 } }
            }
        }
    });
</script>

</body>
</html>
